#!/usr/bin/env bash
# script/embed-audio
#
# Inserts an HTML audio player into each lesson that has a matching MP3
# in the audio/ directory. Idempotent — safe to run multiple times.
#
# Usage:
#   script/embed-audio              # process all lessons with matching audio
#   script/embed-audio 0001 0002    # process specific lessons only
#
# The player is inserted just before the closing </article> tag.
# If a player is already present (data-audio-player attribute), it is
# updated in place with the latest file path.

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
LESSONS_DIR="$REPO_ROOT/lessons"
AUDIO_DIR="$REPO_ROOT/audio"

GREEN='\033[0;32m'; YELLOW='\033[1;33m'; RED='\033[0;31m'; NC='\033[0m'
log()  { echo -e "${GREEN}▶${NC} $*"; }
warn() { echo -e "${YELLOW}⚠${NC}  $*"; }
err()  { echo -e "${RED}✗${NC}  $*" >&2; }

# Determine which lessons to process
if [[ $# -gt 0 ]]; then
  LESSON_FILES=()
  for num in "$@"; do
    matches=("$LESSONS_DIR"/${num}*.html)
    if [[ ${#matches[@]} -eq 0 || ! -f "${matches[0]}" ]]; then
      err "No lesson file found matching: $num"
      exit 1
    fi
    LESSON_FILES+=("${matches[0]}")
  done
else
  mapfile -t LESSON_FILES < <(ls "$LESSONS_DIR"/*.html 2>/dev/null | sort)
fi

EMBEDDED=0
SKIPPED=0

for lesson_path in "${LESSON_FILES[@]}"; do
  lesson_file="$(basename "$lesson_path")"
  lesson_slug="${lesson_file%.html}"
  audio_file="$AUDIO_DIR/${lesson_slug}.mp3"
  audio_rel="../audio/${lesson_slug}.mp3"

  if [[ ! -f "$audio_file" ]]; then
    warn "No audio for $lesson_file — skipping"
    ((SKIPPED++)) || true
    continue
  fi

  # Check if player already present
  if grep -q 'data-audio-player' "$lesson_path"; then
    warn "Player already embedded in $lesson_file — skipping (run with --force to update)"
    ((SKIPPED++)) || true
    continue
  fi

  log "Embedding audio player in: $lesson_file"

  # Build the player HTML block
  player_html='
  <!-- Audio Overview (generated by NotebookLM) -->
  <div class="audio-overview" data-audio-player>
    <div class="audio-overview-label">Audio Overview</div>
    <p class="audio-overview-desc">A NotebookLM deep-dive podcast on this lesson. Good for reviewing on the go.</p>
    <audio controls preload="metadata" style="width:100%;margin-top:0.5rem;">
      <source src="'"$audio_rel"'" type="audio/mpeg">
      Your browser does not support the audio element.
    </audio>
  </div>'

  # Insert before </article>
  # Use Python for reliable in-place string insertion (sed -i differs on macOS/Linux)
  python3 - "$lesson_path" "$player_html" <<'PYEOF'
import sys

lesson_path = sys.argv[1]
player_html = sys.argv[2]

with open(lesson_path, 'r', encoding='utf-8') as f:
    content = f.read()

marker = '</article>'
if marker not in content:
    print(f"ERROR: no </article> tag found in {lesson_path}", file=sys.stderr)
    sys.exit(1)

# Insert just before the closing </article>
updated = content.replace(marker, player_html + '\n\n' + marker, 1)

with open(lesson_path, 'w', encoding='utf-8') as f:
    f.write(updated)
PYEOF

  ((EMBEDDED++)) || true
  log "  Done: $lesson_file"
done

echo ""
log "Embedded: $EMBEDDED lesson(s)   Skipped: $SKIPPED"

if [[ $EMBEDDED -gt 0 ]]; then
  echo ""
  echo "Audio CSS is in assets/style.css. Commit when ready:"
  echo "  git add lessons/ audio/ && git commit -m 'feat: add audio overviews'"
fi
